# ---------------------------------------------------------------------------
# Frontend do BiblioFlix. Copie para ".env.local":
#   cp .env.example .env.local
# ---------------------------------------------------------------------------

# URL pública do API Gateway (backend). O frontend só conversa com ele.
# Local (Docker Compose do repositório backend):
NEXT_PUBLIC_API_URL=http://localhost:8080
# Em produção, aponte para o gateway publicado, ex.:
# NEXT_PUBLIC_API_URL=https://biblioflix-gateway.onrender.com
